{
    "compilerOptions": {
        "target": "es2020",
        "module": "ES2020",
        "esModuleInterop": true,
        "outDir": "./preBuild/_102054_/",
        "rootDir": "./project/_102054_",
        "strict": true,
        "removeComments": false,
        "noUnusedParameters": false,
        "skipLibCheck": false,
